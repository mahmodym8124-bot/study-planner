{
  "name": "mindvault",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "MindVault - clean personal workspace for notes, files, ideas, and focused planning",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "client": "vite --host 0.0.0.0",
    "server": "nodemon server/server.js",
    "start": "node server/server.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint client server --ext .js"
    ,
    "ts:build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "gsap": "^3.15.0",
    "helmet": "^8.0.0",
    "i18next": "^26.1.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "nodemon": "^3.1.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
