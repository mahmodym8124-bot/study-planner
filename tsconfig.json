{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node16",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "outDir": "dist/ts"
  },
  "include": [
    "server/**/*",
    "client/**/*",
    "api/**/*",
    "*.js",
    "client/js/**/*.js",
    "server/**/*.js"
  ],
  "exclude": ["node_modules", "dist"]
}
